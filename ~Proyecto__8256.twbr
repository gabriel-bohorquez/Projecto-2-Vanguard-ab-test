      <aliases enabled='yes' />
      <column caption='Completed' datatype='integer' name='[Calculation_0362498502004736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [process_step] = &quot;confirm&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='time_minutes' datatype='integer' name='[Calculation_0362498521169921]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;minute&apos;, [previous_time], [date_time])' />
      </column>
      <column caption='Tasa abandono' datatype='real' name='[Calculation_0567352201396224]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Calculamos la tasa de abandono restando la tasa de finalización al 100% (1)&#13;&#10;1 - (&#13;&#10;  COUNTD(&#13;&#10;    IF [process_step] = &quot;confirm&quot;&#13;&#10;    THEN [client_id]&#13;&#10;    END&#13;&#10;  )&#13;&#10;  /&#13;&#10;  COUNTD([client_id])&#13;&#10;)' />
      </column>
      <column caption='Completion Rate Correct' datatype='real' name='[Calculation_1947857527099392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF [process_step] = &quot;confirm&quot; THEN [client_id] END&#10;)&#10;/&#10;COUNTD([client_id])' />
      </column>
      <column caption='Completion Rate FINAL' datatype='real' datatype-customized='true' name='[Calculation_1947857531072513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;IF [process_step] = &quot;confirm&quot;&#10;THEN [client_id]&#10;END&#10;)&#10;/&#10;COUNTD([client_id])' />
      </column>
      <column caption='Mejora Observada' datatype='real' name='[Calculation_2636632548687872]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Mejora Observada en formato positivo y multiplicada por 10&#13;&#10;ABS(&#13;&#10;    (&#13;&#10;        COUNTD(IF [Variation] = &quot;Test&quot; AND [process_step] = &quot;confirm&quot; THEN [client_id] END)&#13;&#10;        /&#13;&#10;        COUNTD(IF [Variation] = &quot;Test&quot; THEN [client_id] END)&#13;&#10;    )&#13;&#10;    -&#13;&#10;    (&#13;&#10;        COUNTD(IF [Variation] = &quot;Control&quot; AND [process_step] = &quot;confirm&quot; THEN [client_id] END)&#13;&#10;        /&#13;&#10;        COUNTD(IF [Variation] = &quot;Control&quot; THEN [client_id] END)&#13;&#10;    )&#13;&#10;) * 10' />
      </column>
      <column caption='Tasa de Finalización Real' datatype='real' name='[Calculation_2636632561602561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Tasa de Finalización&#13;&#10;SUM(IF [process_step] = &quot;confirm&quot; THEN 1 ELSE 0 END) / COUNT([visit_id])' />
      </column>
      <column aggregation='None' caption='Clnt Age (agrupación)' datatype='integer' name='[Clnt Age (agrupación)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[clnt_age]' peg='0' size='5' />
      </column>
      <column aggregation='None' caption='Clnt Tenure Yr (agrupación)' datatype='integer' name='[Clnt Tenure Yr (agrupación)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[clnt_tenure_yr]' peg='0' size='5' />
      </column>
      <column datatype='string' name='[Variation]' role='dimension' type='nominal' />

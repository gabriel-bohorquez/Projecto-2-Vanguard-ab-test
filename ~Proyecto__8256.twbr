  <dashboards>
    <dashboard name='A/B Testing' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#141413' fontname='Anthropic Sans,-apple-system,system-ui,Segoe UI,sans-serif' fontsize='14'>Vanguard A/B Test — ¿Vale la pena el nuevo diseño?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#3d3d3a' fontname='Anthropic Sans,-apple-system,system-ui,Segoe UI,sans-serif' fontsize='12'>Contexto: Vanguard probó un nuevo proceso digital con 50.500 clientes entre marzo y junio 2017. ¿Mejoró la experiencia?</run>
          </formatted-text>
        </title>
      </layout-options>
      <style />
      <size maxheight='900' maxwidth='1600' minheight='900' minwidth='1600' sizing-mode='fixed' />
      <zones>
